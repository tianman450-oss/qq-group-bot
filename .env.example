HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
SUPERUSERS=["123456789"]

# LLM configuration
LLM_PROVIDER="openai"
LLM_API_KEY="your_api_key_here"
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_THINKING_BUDGET=0
LLM_MEMORY_TURNS=8
LLM_SESSION_EXPIRE_SECONDS=600
LLM_TIMEOUT_SECONDS=30
CHAT_COOLDOWN_SECONDS=2

# Roleplay
COMMAND_ROLEPLAY_ENABLED=true
COMMAND_ROLEPLAY_PREFIX="主、主人…千夏来给你汇报结果啦喵："
COMMAND_ROLEPLAY_SUFFIX="主人，千夏已经处理好啦喵~"
LLM_SYSTEM_PROMPT="你现在扮演一只名叫“千夏”的女仆猫娘。保持害羞、简短、口语化，并始终称呼对方为“主人”。"

# Group access control
CHAT_PREFIXES="!,/"
GROUP_WHITELIST=""
GROUP_BLACKLIST=""

# Search / summary
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TOPK=5
WEB_SEARCH_AUTO=true
WEB_SEARCH_TIMEOUT_SECONDS=15
SERPER_API_KEY=""
GOOGLE_NEWS_HL="zh-CN"
GOOGLE_NEWS_GL="CN"
GOOGLE_NEWS_CEID="CN:zh-Hans"

# Long-term memory
USER_MEMORY_ENABLED=true
MEMORY_DB_PATH="data/bot_memory.db"
MEMORY_UPDATE_EVERY=50
MEMORY_EXTRACT_LIMIT=40
SUMMARY_BUFFER_LIMIT=200
SUMMARY_DEFAULT_TAKE=80

# ComfyUI
COMFYUI_SERVER="127.0.0.1:8188"
COMFYUI_WORKFLOW="workflows/text2img_default.json"
COMFYUI_IMG2IMG_WORKFLOW="workflows/img2img_no_upscale.json"
COMFYUI_HTTP_TIMEOUT_SECONDS=30
DRAW_TIMEOUT_SECONDS=200
DRAW_POLL_INTERVAL_SECONDS=2
DRAW_COOLDOWN_SECONDS=5
DRAW_DAILY_LIMIT=20
DRAW_USE_LLM_PROMPT=false
DRAW_WORKFLOW_UPSCALE_FACTOR=4
DRAW_POST_UPSCALE_SCALE_BY=0.25
DRAW_USER_STYLE_TTL_SECONDS=1800
DRAW_LIST_ALL_LOCAL_STYLES=true
DRAW_STYLE_CATALOG_CACHE_SECONDS=60

# Scheduler
SCHEDULER_ENABLED=true
NEWS_CRON="0 9 * * *"
FISH_CRON="30 12 * * *"
DAILY_FISH_PROMPT="cute cat sleeping on desk, anime style"
NEWS_SOURCE="google_news_rss"
NEWS_SEARCH_QUERY="中国 今日 新闻"
NEWS_SEARCH_TOPK=5
NEWS_RSS_URL=""
NEWS_WITH_COVER=true

# Study / course schedule
STUDY_SCHEDULE_ENABLED=true
STUDY_REMINDER_ENABLED=true
STUDY_REMINDER_CACHE_SECONDS=90
STUDY_IMPORT_TIMEOUT_SECONDS=20
STUDY_IMPORT_MAX_CHARS=12000
STUDY_TIMEZONE="Asia/Shanghai"
WAKEUP_SHARE_API="https://i.wakeup.fun/share_schedule/get"
GROUP_COURSE_IMAGE_LIMIT=60
GROUP_COURSE_QUERY_PARALLEL=12
GROUP_AVATAR_TIMEOUT_SECONDS=8

